" Indentation
set tabstop=4
set shiftwidth=4
set expandtab
set autoindent
set smartindent

" Display
set number
set relativenumber
set cursorline
set wrap
set showcmd
set showmatch

" Search
set incsearch
set hlsearch
set ignorecase
set smartcase

" Behavior
set backspace=indent,eol,start
set scrolloff=8
set wildmenu

" No swap/backup files
set noswapfile
set nobackup

" Encoding
set encoding=utf-8

" Enable syntax highlighting and filetype detection
syntax on
filetype plugin indent on
